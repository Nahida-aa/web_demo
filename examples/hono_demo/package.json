{
  "name": "hono_demo",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:node": "tsx watch src/api/index.ts",
    "dev:bun": "bun run --hot src/index.bun.ts",
    "dev:wrangler": "wrangler dev",
    "build": "tsc",
    "start": "node dist/index.js",
    "deploy:wrangler": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@hono/node-server": "^1.18.2",
    "@hono/zod-openapi": "^1.1.0",
    "@scalar/hono-api-reference": "^0.9.13",
    "@scalar/openapi-to-markdown": "^0.2.26",
    "drizzle-orm": "^0.44.5",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.9.2",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260130.0",
    "@types/node": "^20.11.17",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "wrangler": "^4.61.1"
  }
}